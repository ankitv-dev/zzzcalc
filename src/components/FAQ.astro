---
import { faqs as defaultFaqs } from "../lib/faq-data.js";

export interface Props {
  faqs?: Array<{ id: string; question: string; answer: string }>;
  subtitle?: string;
}

const { faqs = defaultFaqs, subtitle = "About sleep cycles, timing, and how the calculator works." } = Astro.props;
---

<section class="py-12 sm:py-20">
  <div class="container-main">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-xl sm:text-2xl tracking-tight mb-2 text-center" style="color: var(--text-page);">
        Frequently Asked Questions
      </h2>
      <p class="text-sm text-center mb-8 sm:mb-10" style="color: var(--text-muted);">
        {subtitle}
      </p>

      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="card-primary group open:opacity-100 transition-all cursor-pointer" style="padding: 0;">
            <summary class="flex items-center justify-between gap-3 px-4 sm:px-5 py-3.5 sm:py-4 text-sm sm:text-base font-medium list-none cursor-pointer" style="color: var(--text-card);">
              <span>{faq.question}</span>
              <svg class="w-4 h-4 shrink-0 transition-transform duration-200 group-open:rotate-180" style="color: var(--text-muted);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>
            <div class="px-4 sm:px-5 pb-4 sm:pb-5 text-sm leading-relaxed border-t pt-3" style="color: var(--text-card-muted); border-color: var(--border-card);">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
