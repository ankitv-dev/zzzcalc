<section class="pt-28 pb-12 sm:pt-40 sm:pb-20">
  <div class="container-main">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium mb-5 sm:mb-6" style="background: color-mix(in srgb, var(--color-primary) 10%, transparent); border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent); color: var(--color-primary);">
        <span class="w-1.5 h-1.5 rounded-full animate-pulse-soft" style="background: var(--color-primary);"></span>
        Based on 90-min REM cycle science
      </div>
      <h1 class="font-serif text-3xl sm:text-5xl lg:text-6xl tracking-tight leading-[1.05]" style="color: var(--text-page);">
        Wake up refreshed.<br />
        <span style="color: var(--color-primary);">Every time.</span>
      </h1>
      <p class="text-sm sm:text-base mt-4 sm:mt-5 max-w-xl mx-auto leading-relaxed" style="color: var(--text-muted);">
        Most alarms wake you mid-cycle — leaving you groggy for hours. Zzzcalc finds your cycle-aligned bedtime or wake time so you rise naturally alert.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mt-6 sm:mt-8">
        <a href="#calculator" class="btn-primary w-full sm:w-auto justify-center text-sm">
          Calculate My Schedule
        </a>
        <a href="/nap" class="btn-secondary w-full sm:w-auto justify-center text-sm">
          Power Nap Timer
        </a>
      </div>
    </div>
  </div>
</section>
