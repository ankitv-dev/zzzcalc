---

const rows = [
  { cycles: 6, duration: "9h 00m", label: "Optimal", color: "#5db872" },
  { cycles: 5, duration: "7h 30m", label: "Recommended", color: "#8fc97b" },
  { cycles: 4, duration: "6h 00m", label: "Minimum", color: "#ccb56e" },
  { cycles: 3, duration: "4h 30m", label: "Emergency", color: "#cc785c" },
];
---

<section class="py-12 sm:py-24">
  <div class="container-main">
    <div class="card-primary p-5 sm:p-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-12 items-start">
        <div>
          <span class="badge-pill" style="background: color-mix(in srgb, var(--color-primary) 10%, transparent); color: var(--color-primary); border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);">The Science</span>
          <h2 class="font-serif text-xl sm:text-3xl tracking-tight mt-4 mb-4" style="color: var(--text-card);">
            How the 90-minute cycle works
          </h2>
          <div class="space-y-3 text-sm leading-relaxed" style="color: var(--text-card-muted);">
            <p>
              Human sleep cycles average <strong style="color: var(--text-card);">90 minutes</strong> — established by Kleitman &amp; Dement (1953) using EEG. Each cycle moves through light sleep (N1, N2), deep slow-wave sleep (N3), and REM (dreaming).
            </p>
            <p>
              The average adult takes about <strong style="color: var(--text-card);">14 minutes</strong> to fall asleep after lights-out. Zzzcalc accounts for this latency so your calculated times reflect actual sleep, not just time in bed. You can adjust this in the settings if your personal average differs.
            </p>
            <p>
              Most adults need <strong style="color: var(--text-card);">5–6 cycles</strong> per night (7.5–9 hours) per NSF and AASM guidelines. Waking at a cycle boundary — instead of mid-deep-sleep — eliminates sleep inertia and morning grogginess.
            </p>
          </div>
        </div>

        <div class="rounded-xl p-5 sm:p-6" style="background: var(--bg-soft); border: 1px solid var(--border-card);">
          <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--text-muted);">Quick Reference</h3>
          <div class="space-y-2">
            {rows.map((row) => (
              <div class="flex items-center gap-3 py-2" style="border-bottom: 1px solid var(--border-card);">
                <span class="w-2.5 h-2.5 rounded-full shrink-0" style={`background-color: ${row.color}`}></span>
                <span class="text-sm font-medium" style="color: var(--text-card);">{row.cycles} cycles</span>
                <span class="text-sm" style="color: var(--text-card-muted);">{row.duration}</span>
                <span class="text-xs font-medium ml-auto" style={`color: ${row.color}`}>{row.label}</span>
              </div>
            ))}
          </div>
          <p class="text-[10px] mt-4 leading-relaxed" style="color: var(--text-muted-soft);">
            Based on NSF adult (18-64) recommendations. Individual needs vary. Not medical advice.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
