---
import { CHRONOTYPE_QUESTIONS } from "../lib/cycles.js";
---

<div id="chronotype-quiz" class="card-primary">
  <span class="badge-pill" style="background: color-mix(in srgb, var(--color-primary) 10%, transparent); color: var(--color-primary); border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);">Quiz</span>
  <h2 class="font-serif text-xl sm:text-2xl tracking-tight mt-3 mb-1" style="color: var(--text-card);">What's your chronotype?</h2>
  <p class="text-xs sm:text-sm mb-5" style="color: var(--text-muted);">
    Answer 5 quick questions to personalize your sleep schedule.
  </p>

  <form id="quiz-form" class="space-y-5">
    {CHRONOTYPE_QUESTIONS.map((q, i) => (
      <fieldset class="quiz-fieldset">
        <legend class="text-sm font-medium mb-2" style="color: var(--text-card);">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-xs mr-2 shrink-0" style="background: color-mix(in srgb, var(--color-primary) 15%, transparent); color: var(--color-primary);">{i + 1}</span>
          {q.q}
        </legend>
        <div class="space-y-1.5 ml-7">
          {q.options.map((opt) => (
            <label class="quiz-option flex items-center gap-2 px-3 py-2 rounded-md cursor-pointer text-sm" style="border: 1px solid var(--border-card); background: var(--bg-soft); transition: all 0.15s;">
              <input type="radio" name={`q-${i}`} value={opt.value} class="quiz-radio" />
              <span style="color: var(--text-card-muted);">{opt.label}</span>
            </label>
          ))}
        </div>
      </fieldset>
    ))}
  </form>

  <button id="quiz-submit" class="btn-primary w-full justify-center mt-6 text-sm">
    See my chronotype
  </button>
  <p id="quiz-result" class="mt-3 text-sm text-center hidden" style="color: var(--text-card);"></p>
  <p id="quiz-error" class="mt-3 text-xs text-center hidden" style="color: #c64545;"></p>
</div>

<script>
  import { chronotypeFromScore } from "../lib/cycles.js";

  const form = document.getElementById("quiz-form");
  const submitBtn = document.getElementById("quiz-submit");
  const resultEl = document.getElementById("quiz-result");
  const errorEl = document.getElementById("quiz-error");

  submitBtn.addEventListener("click", () => {
    const radios = form.querySelectorAll(".quiz-radio:checked");
    if (radios.length < 5) {
      errorEl.textContent = "Please answer all 5 questions.";
      errorEl.classList.remove("hidden");
      return;
    }
    errorEl.classList.add("hidden");

    let score = 0;
    radios.forEach((r) => { score += parseInt(r.value, 10); });

    const chronotype = chronotypeFromScore(score);

    try {
      localStorage.setItem("zzzcalc-chronotype", JSON.stringify(chronotype));
    } catch (e) {}

    resultEl.classList.remove("hidden");
    const emoji = chronotype.id === "lark" ? "🌅" : chronotype.id === "owl" ? "🦉" : "☀️";
    resultEl.innerHTML = `
      <div class="flex flex-col items-center gap-2">
        <span class="text-2xl">${emoji}</span>
        <span class="font-semibold text-lg">${chronotype.label}</span>
        <span class="text-sm" style="color: var(--text-muted);">Shift: ${chronotype.shift !== 0 ? (chronotype.shift > 0 ? "+" : "") + chronotype.shift + " min" : "None"}</span>
        <p class="text-xs mt-1" style="color: var(--text-muted);">
          ${chronotype.id === "lark" ? "You're naturally wired for early mornings. Your body's ideal bedtime and wake times are shifted 30 minutes earlier than average." : chronotype.id === "owl" ? "You hit your stride later in the day. Your body's ideal sleep times are shifted 30 minutes later than average." : "You fall right in the middle of the spectrum. No time adjustment needed."}
        </p>
        <a href="/" class="btn-primary text-xs mt-3 px-4 py-2" style="text-decoration: none;">Use in calculator</a>
      </div>
    `;
    submitBtn.disabled = true;
    submitBtn.style.opacity = "0.5";
    submitBtn.style.cursor = "default";
  });
</script>

<style is:global>
  .quiz-option:has(.quiz-radio:checked) { border-color: var(--color-primary); background: color-mix(in srgb, var(--color-primary) 8%, transparent); }
  .quiz-radio { accent-color: var(--color-primary); }
  .quiz-fieldset { border: none; padding: 0; margin: 0; }
  .quiz-fieldset:focus-visible { outline: none; }
  .quiz-option:focus-within { outline: 2px solid var(--color-primary); outline-offset: 1px; }
</style>
