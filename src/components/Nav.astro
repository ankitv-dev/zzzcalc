---
const links = [
  { href: "/", label: "Calculator" },
  { href: "/nap", label: "Power Nap" },
  { href: "/about", label: "About" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50" style="background: var(--nav-bg); backdrop-filter: blur(12px); border-bottom: 1px solid var(--nav-border);">
  <div class="container-main flex items-center justify-between h-14 sm:h-16">
    <a href="/" class="flex items-center gap-2 group shrink-0">
      <span class="font-serif text-lg sm:text-xl tracking-tight leading-none transition-colors" style="color: var(--color-primary);">ZzzCalc</span>
    </a>
    <div class="flex items-center gap-1">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="px-2.5 sm:px-3 py-2 text-sm font-medium rounded-md transition-colors"
            style="color: var(--text-muted);"
            onMouseOver="this.style.color='var(--text-card)'"
            onMouseOut="this.style.color='var(--text-muted)'"
          >
            {link.label}
          </a>
        ))
      }
      <button id="theme-toggle" class="p-2 rounded-md transition-colors" style="color: var(--text-muted);" title="Toggle theme">
        <svg id="theme-icon-moon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="theme-icon-sun" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  document.addEventListener("DOMContentLoaded", initTheme);
  if (document.readyState !== "loading") initTheme();

  function initTheme() {
    const toggle = document.getElementById("theme-toggle");
    const moonIcon = document.getElementById("theme-icon-moon");
    const sunIcon = document.getElementById("theme-icon-sun");
    if (!toggle) return;

    const saved = localStorage.getItem("zzzcalc-settings");
    let theme = "dark";
    if (saved) {
      try { const s = JSON.parse(saved); if (s.theme) theme = s.theme; } catch (e) {}
    }

    applyThemeUI(theme);

    toggle.addEventListener("click", () => {
      const current = document.documentElement.dataset.theme || "dark";
      const next = current === "dark" ? "light" : "dark";
      applyThemeUI(next);
      try {
        const saved = localStorage.getItem("zzzcalc-settings");
        const settings = saved ? JSON.parse(saved) : {};
        settings.theme = next;
        localStorage.setItem("zzzcalc-settings", JSON.stringify(settings));
      } catch (e) {}
    });
  }

  function applyThemeUI(theme) {
    document.documentElement.dataset.theme = theme;
    const moonIcon = document.getElementById("theme-icon-moon");
    const sunIcon = document.getElementById("theme-icon-sun");
    if (moonIcon) moonIcon.classList.toggle("hidden", theme !== "dark");
    if (sunIcon) sunIcon.classList.toggle("hidden", theme !== "light");
  }
</script>
