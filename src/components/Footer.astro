---
const copyright = `2025–${new Date().getFullYear()}`;
const bottomLinks = [
  { href: "/privacy", label: "Privacy" },
  { href: "/terms", label: "Terms" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<footer style="border-top: 1px solid var(--footer-border); margin-top: 6rem;">
  <div class="container-main py-10 sm:py-16">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-8">
      <div class="col-span-2 sm:col-span-1">
        <span class="font-serif text-lg tracking-tight" style="color: var(--text-page);">ZzzCalc</span>
        <p class="text-sm mt-2 max-w-xs" style="color: var(--text-muted);">
          Wake up refreshed. Science-based sleep cycle calculator using the 90-minute REM cycle model.
        </p>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--text-muted);">Calculator</h3>
        <ul class="space-y-1.5">
          <li><a href="/" class="footer-link text-sm" style="color: var(--text-muted);">Bedtime Calculator</a></li>
          <li><a href="/" class="footer-link text-sm" style="color: var(--text-muted);">Wake-Up Calculator</a></li>
          <li><a href="/nap" class="footer-link text-sm" style="color: var(--text-muted);">Power Nap Timer</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--text-muted);">Science</h3>
        <ul class="space-y-1.5">
          <li class="text-sm" style="color: var(--text-muted);">90-min sleep cycles</li>
          <li class="text-sm" style="color: var(--text-muted);">14-min avg sleep latency</li>
          <li class="text-sm" style="color: var(--text-muted);">NSF age guidelines</li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--text-muted);">Company</h3>
        <ul class="space-y-1.5">
          <li><a href="/about" class="footer-link text-sm" style="color: var(--text-muted);">About Us</a></li>
          <li><a href="/contact" class="footer-link text-sm" style="color: var(--text-muted);">Contact Us</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--text-muted);">Legal</h3>
        <ul class="space-y-1.5">
          <li><a href="/privacy" class="footer-link text-sm" style="color: var(--text-muted);">Privacy Policy</a></li>
          <li><a href="/terms" class="footer-link text-sm" style="color: var(--text-muted);">Terms &amp; Conditions</a></li>
          <li class="text-sm" style="color: var(--text-muted);">Not medical advice</li>
        </ul>
      </div>
    </div>
    <div class="mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3" style="border-top: 1px solid var(--footer-border);">
      <p class="text-xs" style="color: var(--text-muted);">&copy; {copyright} ZzzCalc. Wake up refreshed.</p>
      <div class="flex items-center gap-3 text-xs" style="color: var(--text-muted);">
        {bottomLinks.map((l) => (
          <a href={l.href} class="footer-link">{l.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style is:global>
  .footer-link { transition: color 0.15s ease; }
  .footer-link:hover, .footer-link:focus-visible { color: var(--text-card) !important; }
  .footer-link:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; border-radius: 2px; }
</style>
