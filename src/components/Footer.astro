---
---

<footer style="border-top:1px solid var(--footer-border);margin-top:6rem;">
  <div class="container-main py-10 sm:py-16">
    <div class="border-b pb-8 mb-8" style="border-color:var(--footer-border);">
      <p class="font-serif text-lg tracking-tight" style="color:var(--text-page);">ZzzCalc</p>
      <p class="text-sm mt-1 max-w-lg" style="color:var(--text-muted);">
        Wake up refreshed. Science-based sleep cycle calculator using the 90-minute REM cycle model.
      </p>
    </div>
    <div class="flex flex-col sm:flex-row justify-between gap-4">
      <nav class="flex flex-wrap gap-x-6 gap-y-1">
        <a href="/" class="footer-link text-sm no-underline" style="color:var(--text-muted);">Home</a>
        <a href="/about" class="footer-link text-sm no-underline" style="color:var(--text-muted);">About</a>
        <a href="/contact" class="footer-link text-sm no-underline" style="color:var(--text-muted);">Contact</a>
        <a href="/privacy" class="footer-link text-sm no-underline" style="color:var(--text-muted);">Privacy</a>
        <a href="/terms" class="footer-link text-sm no-underline" style="color:var(--text-muted);">Terms</a>
      </nav>
      <p class="text-xs" style="color:var(--text-muted);">
        &copy; {new Date().getFullYear()} ZzzCalc. Not medical advice — always consult a healthcare provider for sleep concerns.
      </p>
    </div>
  </div>
</footer>

<style is:global>
  .footer-link { transition: color 0.15s ease; }
  .footer-link:hover, .footer-link:focus-visible { color: var(--text-card) !important; }
  .footer-link:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; border-radius: 2px; }
</style>
