---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import ScienceCard from "../components/ScienceCard.astro";
import Calculator from "../components/Calculator.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";
import { faqStructuredData, breadcrumbStructuredData } from "../lib/faq-data.js";
---

<Layout
  title="Sleep Calculator — Bedtime Calculator & Wake-Up Time | ZzzCalc"
  description="What time should you go to sleep? ZzzCalc is a free sleep &amp; bedtime calculator based on 90-minute REM cycles. Find your ideal bedtime or wake-up time."
  canonical="https://zzzcalc.vercel.app"
  structuredData={[
    faqStructuredData,
    breadcrumbStructuredData([
      { name: "Home", url: "https://zzzcalc.vercel.app" },
    ]),
  ]}
>
  <Nav />
  <Hero />

  <section id="calculator" class="py-6 sm:py-12">
    <div class="container-main">
      <div class="max-w-2xl mx-auto">
        <Calculator />
      </div>
    </div>
  </section>

  <section class="py-12 sm:py-20">
    <div class="container-main">
      <div class="max-w-3xl mx-auto" style="color: var(--text-muted); line-height: 1.75;">
        <h2 class="font-serif text-xl sm:text-2xl tracking-tight mb-4" style="color: var(--text-page);">
          A sleep calculator built around your biology
        </h2>

        <p class="text-sm sm:text-base">
          If you have ever asked yourself <strong style="color: var(--text-card);">"what time should I go to sleep?"</strong> or <strong style="color: var(--text-card);">"what time should I wake up?"</strong>, the answer is not about a fixed hour — it is about your sleep cycles. Human sleep moves through repeating 90-minute cycles — light sleep (N1, N2), deep slow-wave sleep (N3), and REM — all night long. Waking at the end of a cycle, when your brain is naturally closest to the surface, is the difference between feeling alert and spending the first hour of your day in a fog. That is the principle behind every good <strong style="color: var(--text-card);">sleep calculator</strong>.
        </p>

        <p class="text-sm sm:text-base mt-4">
          ZzzCalc is a free <strong style="color: var(--text-card);">bedtime calculator</strong> and <strong style="color: var(--text-card);">wake-up time calculator</strong> that works backward from your target wake time — or forward from your bedtime — in 90-minute blocks. It accounts for the average 14 minutes it takes to fall asleep, then shows you every cycle-aligned option from 4 to 6 cycles. Each result includes a quality rating so you can decide what trade-off works for your schedule.
        </p>

        <p class="text-sm sm:text-base mt-4">
          Sleep needs change across your lifetime, which is why a proper <strong style="color: var(--text-card);">sleep cycle calculator by age</strong> matters. Teens need 8-10 hours (6-7 cycles), adults need 7-9 hours (5-6 cycles), and seniors often do best with 7-8 hours (5 cycles). ZzzCalc lets you experiment with different cycle counts to find what works for you — whatever your age or schedule.
        </p>

        <p class="text-sm sm:text-base mt-4">
          The same math applies whether you are a shift worker planning daytime sleep, a parent working around a newborn, or someone trying to shake off that mid-afternoon slump with a power nap. No account needed. No data tracked. Just the calculation.
        </p>
      </div>
    </div>
  </section>

  <Features />
  <FAQ />
  <ScienceCard />
  <Footer />
</Layout>
