---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Sleep Debt Tracker — ZzzCalc"
  description="Track your sleep debt over the past 7 or 14 days. Log your bedtimes and wake times to calculate cumulative sleep debt."
  canonical="https://zzzcalc.vercel.app/debt"
>
  <Nav />

  <section class="pt-28 pb-16 sm:pt-40 sm:pb-24">
    <div class="container-main">
      <div class="max-w-3xl mx-auto">
        <h1 class="font-serif text-2xl sm:text-3xl lg:text-4xl tracking-tight mb-1" style="color: var(--text-page);">Sleep Debt Tracker</h1>
        <p class="text-sm mb-6" style="color: var(--text-muted);">Log your sleep and track cumulative debt over time. All data stays on your device.</p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
          <div class="card-primary p-4 text-center">
            <span class="text-[10px] uppercase tracking-widest" style="color: var(--text-muted);">7-day avg</span>
            <div id="debt-7d-avg" class="text-2xl font-semibold mt-1 font-serif" style="color: var(--text-card);">--h</div>
          </div>
          <div class="card-primary p-4 text-center">
            <span class="text-[10px] uppercase tracking-widest" style="color: var(--text-muted);">14-day avg</span>
            <div id="debt-14d-avg" class="text-2xl font-semibold mt-1 font-serif" style="color: var(--text-card);">--h</div>
          </div>
          <div class="card-primary p-4 text-center">
            <span class="text-[10px] uppercase tracking-widest" style="color: var(--text-muted);">Total debt</span>
            <div id="debt-total" class="text-2xl font-semibold mt-1 font-serif" style="color: var(--text-card);">--h</div>
          </div>
        </div>

        <div class="card-primary p-4 sm:p-6">
          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <div class="flex-1">
              <label class="sleep-label" for="debt-bed">Bedtime</label>
              <input id="debt-bed" type="time" class="sleep-input" value="23:00" />
            </div>
            <div class="flex-1">
              <label class="sleep-label" for="debt-wake">Wake time</label>
              <input id="debt-wake" type="time" class="sleep-input" value="07:00" />
            </div>
            <div class="flex-1">
              <label class="sleep-label" for="debt-date">Date</label>
              <input id="debt-date" type="date" class="sleep-input" />
            </div>
          </div>
          <button id="debt-log-btn" class="btn-primary w-full justify-center text-sm">Log tonight</button>
        </div>

        <div id="debt-log-container" class="mt-4 space-y-1">
          <div class="text-xs font-medium mb-2" style="color: var(--text-muted);">Sleep log</div>
          <div id="debt-log-list" class="space-y-1"></div>
        </div>

        <div class="mt-4 flex gap-2 text-xs">
          <button id="debt-clear" class="px-3 py-1.5 rounded-md" style="background: transparent; color: var(--text-muted-soft); border: 1px solid var(--border-card); cursor: pointer; font-family: var(--font-sans);">Clear all data</button>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const bedInput = document.getElementById("debt-bed");
  const wakeInput = document.getElementById("debt-wake");
  const dateInput = document.getElementById("debt-date");
  const logBtn = document.getElementById("debt-log-btn");
  const logList = document.getElementById("debt-log-list");
  const avg7El = document.getElementById("debt-7d-avg");
  const avg14El = document.getElementById("debt-14d-avg");
  const debtTotalEl = document.getElementById("debt-total");
  const clearBtn = document.getElementById("debt-clear");

  function calcSleepHours(bedStr, wakeStr) {
    const [bh, bm] = bedStr.split(":").map(Number);
    const [wh, wm] = wakeStr.split(":").map(Number);
    let hours = wh - bh + (wm - bm) / 60;
    if (hours < 0) hours += 24;
    return hours;
  }

  function getLogs() {
    try {
      return JSON.parse(localStorage.getItem("zzzcalc-debt") || "[]");
    } catch (e) { return []; }
  }

  function saveLogs(logs) {
    localStorage.setItem("zzzcalc-debt", JSON.stringify(logs));
  }

  function renderLogs() {
    const logs = getLogs();
    if (!logs.length) {
      logList.innerHTML = '<div class="text-xs py-4 text-center" style="color: var(--text-muted-soft);">No entries yet. Log your first night above.</div>';
      avg7El.textContent = "--h";
      avg14El.textContent = "--h";
      debtTotalEl.textContent = "--h";
      return;
    }

    const sorted = logs.sort((a, b) => b.date.localeCompare(a.date));

    logList.innerHTML = sorted.slice(0, 30).map((l) => `
      <div class="flex items-center gap-3 p-2 rounded-lg text-xs" style="background: var(--bg-soft); border: 1px solid var(--border-card);">
        <span class="w-24 shrink-0" style="color: var(--text-card);">${l.date}</span>
        <span style="color: var(--text-muted);">${l.bed} → ${l.wake}</span>
        <span class="ml-auto font-medium" style="color: var(--text-card);">${l.hours.toFixed(1)}h</span>
      </div>
    `).join("");

    const last7 = sorted.slice(0, 7);
    const last14 = sorted.slice(0, 14);
    const avg7 = last7.reduce((s, l) => s + l.hours, 0) / last7.length;
    const avg14 = last14.reduce((s, l) => s + l.hours, 0) / last14.length;
    const target = 7.5;
    const totalDebt = Math.max(0, (target - avg7) * 7);

    avg7El.textContent = `${avg7.toFixed(1)}h`;
    avg14El.textContent = `${avg14.toFixed(1)}h`;
    debtTotalEl.textContent = `${totalDebt.toFixed(1)}h`;
    [avg7El, avg14El].forEach((el) => {
      const val = parseFloat(el.textContent);
      el.style.color = val >= 7 ? "var(--text-card)" : val >= 6 ? "#ccb56e" : "#cc785c";
    });
    debtTotalEl.style.color = totalDebt > 0 ? "#cc785c" : "var(--text-card)";
  }

  function logEntry() {
    const bed = bedInput.value;
    const wake = wakeInput.value;
    const date = dateInput.value;
    if (!bed || !wake || !date) return;

    const hours = calcSleepHours(bed, wake);
    const logs = getLogs();

    const existingIdx = logs.findIndex((l) => l.date === date);
    const entry = { date, bed, wake, hours: Math.round(hours * 10) / 10 };

    if (existingIdx >= 0) {
      logs[existingIdx] = entry;
    } else {
      logs.push(entry);
    }

    saveLogs(logs);
    renderLogs();
    logBtn.textContent = "Logged!";
    setTimeout(() => { logBtn.textContent = "Log tonight"; }, 1500);
  }

  function setDefaultDate() {
    const d = new Date();
    dateInput.value = d.toISOString().split("T")[0];
  }

  logBtn.addEventListener("click", logEntry);
  clearBtn.addEventListener("click", () => {
    if (confirm("Clear all sleep data? This cannot be undone.")) {
      saveLogs([]);
      renderLogs();
    }
  });

  setDefaultDate();
  renderLogs();
</script>

<style is:global>
  #debt-log-list .flex:hover { border-color: var(--border-card-hover); transition: border-color 0.15s; }
</style>
