---
import Layout from "../layouts/Layout.astro";
import PowerNapTimer from "../components/PowerNapTimer.astro";
import FAQ from "../components/FAQ.astro";
import { napFaqs, napFaqStructuredData, breadcrumbStructuredData } from "../lib/faq-data.js";
---

<Layout
  title="Power Nap Timer — Sleep Cycle Calculator | ZzzCalc"
  description="Free power nap timer with NASA-backed protocols. Choose a 20-minute power nap, coffee nap, or 90-minute full sleep cycle. Wake up refreshed, not groggy."
  canonical="https://zzzcalc.vercel.app/nap"
  structuredData={[
    napFaqStructuredData,
    breadcrumbStructuredData([
      { name: "Home", url: "https://zzzcalc.vercel.app" },
      { name: "Power Nap Timer", url: "https://zzzcalc.vercel.app/nap" },
    ]),
  ]}
>
  <section class="pt-28 pb-12 sm:pt-40 sm:pb-20">
    <div class="container-main">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-6 sm:mb-8">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium mb-3 sm:mb-4" style="background: color-mix(in srgb, var(--color-primary) 10%, transparent); border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent); color: var(--color-primary);">
            ⏱️ NASA-backed protocol
          </div>
          <h1 class="font-serif text-2xl sm:text-4xl lg:text-5xl tracking-tight" style="color: var(--text-page);">
            Power Nap Timer
          </h1>
          <p class="text-sm mt-2 sm:mt-3 max-w-md mx-auto" style="color: var(--text-muted);">
            Time your nap to wake at the end of a sleep stage — not mid-deep-sleep. Avoid sleep inertia and feel alert faster.
          </p>
        </div>

        <PowerNapTimer />

        <div class="mt-6 sm:mt-8 card-primary">
          <h3 class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--text-muted);">Nap timing guide</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 text-sm">
            <div class="p-3 rounded-lg" style="background: var(--bg-soft);">
              <span class="font-medium block mb-1" style="color: var(--color-primary);">⚡ Power Nap (20m)</span>
              <span class="text-xs" style="color: var(--text-card-muted);">N1/N2 only. Boosts alertness and motor performance without grogginess. Best for a midday reset.</span>
            </div>
            <div class="p-3 rounded-lg" style="background: var(--bg-soft);">
              <span class="font-medium block mb-1" style="color: var(--color-primary);">☕ Coffee Nap (15m)</span>
              <span class="text-xs" style="color: var(--text-card-muted);">Drink coffee, then nap immediately. Wake up right as the caffeine kicks in. Double the alertness boost.</span>
            </div>
            <div class="p-3 rounded-lg" style="background: var(--bg-soft);">
              <span class="font-medium block mb-1" style="color: var(--color-primary);">🌙 Full Cycle (90m)</span>
              <span class="text-xs" style="color: var(--text-card-muted);">Complete REM cycle. Best for creativity, emotional reset, and memory consolidation. Takes longer to wake from.</span>
            </div>
          </div>
          <p class="text-[10px] mt-4" style="color: var(--text-muted-soft);">
            Avoid 30-60 minute naps — they wake you mid-N3 deep sleep, causing 20-45 minutes of sleep inertia.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-12 sm:pb-20">
    <div class="container-main">
      <div class="max-w-3xl mx-auto" style="color: var(--text-muted); line-height: 1.75;">
        <h2 class="font-serif text-xl sm:text-2xl tracking-tight mb-4" style="color: var(--text-page);">
          The science behind strategic napping
        </h2>

        <p class="text-sm sm:text-base">
          A power nap is not just a short sleep — it is a biologically timed intervention. The key is understanding sleep inertia, the groggy state that occurs when you wake from deep N3 slow-wave sleep. By limiting your nap to 20 minutes, you stay within the lighter N1 and N2 sleep stages where your brain can reset adenosine levels without descending into the deep sleep that leaves you disoriented. This is the principle that NASA validated in its landmark studies on sleep-deprived pilots.
        </p>

        <p class="text-sm sm:text-base mt-4">
          The <strong style="color: var(--text-card);">coffee nap</strong> takes this further. Caffeine blocks adenosine receptors in your brain — the same chemical that builds up throughout the day and makes you feel tired. By drinking coffee immediately before a 15-minute nap, you allow your body to clear some adenosine during sleep while the caffeine reaches peak bloodstream concentration at exactly the moment you wake. The result is a compound alertness boost that studies show outperforms either strategy alone.
        </p>

        <p class="text-sm sm:text-base mt-4">
          For deeper restoration, a <strong style="color: var(--text-card);">90-minute full-cycle nap</strong> allows your brain to pass through all sleep stages including REM. This supports creativity, emotional regulation, and memory consolidation. The trade-off is a longer time commitment and a brief period of grogginess as you emerge from REM. Choose your nap length based on your goal: tactical alertness (20 min), maximized efficiency (15 min coffee nap), or deep cognitive recovery (90 min).
        </p>
      </div>
    </div>
  </section>

  <section class="pb-12 sm:pb-20">
    <div class="container-main">
      <div class="max-w-2xl mx-auto">
        <a href="/" class="card-primary block transition-all hover:opacity-90" style="text-decoration: none;">
          <div class="flex items-center gap-4">
            <div class="text-3xl shrink-0">🌙</div>
            <div>
              <h3 class="font-serif text-lg sm:text-xl tracking-tight" style="color: var(--text-card);">
                Try the full sleep cycle calculator
              </h3>
              <p class="text-sm mt-1" style="color: var(--text-card-muted);">
                Plan your entire night's sleep with cycle-aligned bedtimes and wake times. Works for shift workers, parents, and anyone who wants to wake up refreshed.
              </p>
              <span class="inline-flex items-center gap-1 text-xs font-medium mt-2" style="color: var(--color-primary);">
                Calculate your ideal bedtime →
              </span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <FAQ faqs={napFaqs} subtitle="About power napping, coffee naps, and sleep inertia." />
</Layout>
