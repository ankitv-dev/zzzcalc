---
import Layout from "../layouts/Layout.astro";
import { breadcrumbStructuredData } from "../lib/faq-data.js";
---

<Layout
  title="404 — Page Not Found | ZzzCalc"
  description="The page you are looking for does not exist."
  canonical="https://zzzcalc.vercel.app/404"
  robots="noindex, follow"
  structuredData={[
    breadcrumbStructuredData([
      { name: "Home", url: "https://zzzcalc.vercel.app" },
      { name: "404 — Page Not Found", url: "https://zzzcalc.vercel.app/404" },
    ]),
  ]}
>
  <section class="pt-28 pb-24 sm:pt-40 sm:pb-32">
    <div class="container-main">
      <div class="max-w-xl mx-auto text-center">
        <span class="text-6xl sm:text-7xl font-serif tracking-tight" style="color: var(--color-primary);">404</span>
        <h1 class="font-serif text-xl sm:text-2xl tracking-tight mt-4 mb-3" style="color: var(--text-page);">Page not found</h1>
        <p class="text-sm mb-6" style="color: var(--text-muted);">The page you are looking for does not exist or has been moved.</p>
        <a href="/" class="btn-primary">Back to Calculator</a>
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mt-8 text-sm" style="color: var(--text-muted);">
          <a href="/about" class="no-underline" style="color: var(--text-muted);">About</a>
          <a href="/nap" class="no-underline" style="color: var(--text-muted);">Power Nap Timer</a>
          <a href="/contact" class="no-underline" style="color: var(--text-muted);">Contact</a>
          <a href="/privacy" class="no-underline" style="color: var(--text-muted);">Privacy</a>
          <a href="/terms" class="no-underline" style="color: var(--text-muted);">Terms</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
